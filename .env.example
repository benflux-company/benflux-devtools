# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=benflux
POSTGRES_PASSWORD=benflux_secret
POSTGRES_DB=benflux_devtools
DATABASE_URL=postgresql://benflux:benflux_secret@localhost:5432/benflux_devtools

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_very_long_random_secret_string_at_least_64_chars
JWT_REFRESH_SECRET=change_me_to_another_very_long_random_secret_string_at_least_64

# ─── GitHub OAuth App ─────────────────────────────────────────────────────────
# Create at: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

# ─── GitHub API (Personal Access Token or App token) ─────────────────────────
# Needs: repo, issues, labels read/write permissions
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_OWNER=benflux-company
GITHUB_REPO=benflux-devtools

# ─── App URLs ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── API Server ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
