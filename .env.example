# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=benflux
POSTGRES_PASSWORD=benflux_secret
POSTGRES_DB=benflux_devtools
DATABASE_URL=postgresql://benflux:benflux_secret@localhost:5432/benflux_devtools

# ─── benflux-auth (SSO) ───────────────────────────────────────────────────────
# Login/session are handled entirely by benflux-auth; this app only verifies
# the session it vouches for. GATEWAY_HMAC_SECRET must match the value
# benflux-auth signs with — get it from whoever manages its secrets, it can't
# be generated locally.
AUTH_API_URL=http://localhost:3100
AUTH_PUBLIC_URL=http://localhost:3100
GATEWAY_HMAC_SECRET=ask_the_team_for_the_shared_benflux_auth_value

# ─── GitHub API (Personal Access Token or App token) ─────────────────────────
# Needs: repo, issues, labels read/write permissions. Unrelated to login —
# used only for PR/issue automation on the weekly challenges.
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_OWNER=benflux-company
GITHUB_REPO=benflux-devtools

# ─── App URLs ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_PUBLIC_URL=http://localhost:3100

# ─── API Server ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
