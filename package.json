{
  "name": "benflux-devtools",
  "version": "1.0.0",
  "private": true,
  "description": "Benflux DevTools — Community-driven developer tools platform powered by DevArena",
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "turbo run prisma:migrate",
    "db:generate": "turbo run prisma:generate",
    "db:seed": "turbo run prisma:seed",
    "db:studio": "turbo run prisma:studio"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
